# --- Shopify app credentials (filled by `shopify app config link` / `shopify app dev`) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://localhost
SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders,read_merchant_managed_fulfillment_orders,read_locations

# --- Database ---
# Production target is Postgres (DEVELOPMENT_SPEC §6). For a quick local spin-up
# you can point this at a local Postgres instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stocksentry?schema=public

# --- Observability (optional) ---
SENTRY_DSN=
LOG_LEVEL=info

# --- Reconciliation job ---
# How much safety stock to hold back from `available` by default (units).
DEFAULT_POOL_BUFFER=0
# Reconciliation cron interval (minutes) for the worker process.
RECONCILE_INTERVAL_MINUTES=15
